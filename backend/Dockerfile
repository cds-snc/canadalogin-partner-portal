# --------- requirements ---------

FROM python:3.14-slim as requirements-stage

WORKDIR /tmp

RUN pip install poetry poetry-plugin-export

COPY ./pyproject.toml ./poetry.lock* /tmp/

RUN poetry export -f requirements.txt --output requirements.txt --without-hashes


# --------- final image build ---------
FROM python:3.14-slim

WORKDIR /code

ARG ENVIRONMENT=local
ARG APP_NAME=FastAPI app
ARG APP_DESCRIPTION=
ARG APP_VERSION=
ARG CONTACT_NAME=
ARG CONTACT_EMAIL=
ARG LICENSE_NAME=MIT
ARG TERMS_VERSION=v1
ARG POSTGRES_USER=postgres
ARG POSTGRES_PASSWORD=postgres
ARG POSTGRES_SERVER=db
ARG POSTGRES_PORT=5432
ARG POSTGRES_DB=postgres
ARG SESSION_COOKIE_NAME=app_session
ARG SESSION_COOKIE_SECURE=true
ARG SESSION_COOKIE_DOMAIN=.canada.ca
ARG SESSION_MAX_AGE=1800
ARG SESSION_ROLLING=true
ARG SESSION_COOKIE_SAMESITE=lax
ARG REDIS_CACHE_HOST=
ARG REDIS_CACHE_PORT=6379
ARG REDIS_CACHE_DB=
ARG REDIS_CACHE_PASSWORD=
ARG REDIS_CACHE_SSL=
ARG REDIS_QUEUE_HOST=
ARG REDIS_QUEUE_PORT=6379
ARG REDIS_QUEUE_DB=
ARG REDIS_QUEUE_PASSWORD=
ARG REDIS_QUEUE_SSL=
ARG REDIS_RATE_LIMIT_HOST=
ARG REDIS_RATE_LIMIT_PORT=6379
ARG REDIS_RATE_LIMIT_DB=
ARG REDIS_RATE_LIMIT_PASSWORD=
ARG REDIS_RATE_LIMIT_SSL=
ARG REDIS_SESSION_HOST=redis
ARG REDIS_SESSION_PORT=6379
ARG REDIS_SESSION_DB=1
ARG REDIS_SESSION_PASSWORD=
ARG REDIS_SESSION_SSL=false
ARG REDIS_SESSION_PREFIX=app.sessions.
ARG REDIS_SESSION_GC_TTL=3600
ARG OIDC_ENABLED=false
ARG OIDC_PROVIDER_NAME=oidc
ARG OIDC_SERVER_METADATA_URL=
ARG OIDC_CLIENT_ID=
ARG OIDC_CLIENT_SECRET=
ARG OIDC_SCOPES=openid profile email
ARG OIDC_REDIRECT_URI=
ARG OIDC_REDIRECT_PATH=/api/v1/auth/oidc/callback
ARG OIDC_POST_LOGIN_REDIRECT=/auth-complete
ARG OIDC_ACCESS_DENIED_REDIRECT=/access-denied
ARG OIDC_GROUP_CLAIM_KEY=groupIds
ARG OIDC_ADMIN_GROUP_NAME=admin
ARG OIDC_APPLICATION_OWNERS_GROUP_NAME=application owners
ARG CLPP_ADMIN_ROLE_NAME=admin
ARG CLPP_APPLICATION_OWNERS_ROLE_NAME=application owners
ARG IBM_SV_ADMIN_BASE_URL=
ARG IBM_SV_ADMIN_CLIENT_ID=
ARG IBM_SV_ADMIN_CLIENT_SECRET=
ARG TIMEZONE=America/Toronto
ARG LOAD_MAU_ENABLED=false
ARG CORS_ORIGINS=["*"]
ARG CORS_METHODS=["*"]
ARG CORS_HEADERS=["*"]
ARG CLIENT_CACHE_MAX_AGE=30
ARG AWS_S3_REGION=ca-central-1
ARG AWS_S3_ROLE_ARN=
ARG AWS_S3_PROFILE=
ARG S3_MAU_BUCKET_NAME=
ARG S3_MAU_FOLDER=ibm_verify/app_login_counts/
ARG START_ARQ_ON_STARTUP=false
ARG CONSOLE_LOG_FORMAT_JSON=true

ENV ENVIRONMENT=${ENVIRONMENT}
ENV APP_NAME=${APP_NAME}
ENV APP_DESCRIPTION=${APP_DESCRIPTION}
ENV APP_VERSION=${APP_VERSION}
ENV CONTACT_NAME=${CONTACT_NAME}
ENV CONTACT_EMAIL=${CONTACT_EMAIL}
ENV LICENSE_NAME=${LICENSE_NAME}
ENV TERMS_VERSION=${TERMS_VERSION}
ENV POSTGRES_USER=${POSTGRES_USER}
ENV POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
ENV POSTGRES_SERVER=${POSTGRES_SERVER}
ENV POSTGRES_PORT=${POSTGRES_PORT}
ENV POSTGRES_DB=${POSTGRES_DB}
ENV SESSION_COOKIE_NAME=${SESSION_COOKIE_NAME}
ENV SESSION_COOKIE_SECURE=${SESSION_COOKIE_SECURE}
ENV SESSION_COOKIE_DOMAIN=${SESSION_COOKIE_DOMAIN}
ENV SESSION_MAX_AGE=${SESSION_MAX_AGE}
ENV SESSION_ROLLING=${SESSION_ROLLING}
ENV SESSION_COOKIE_SAMESITE=${SESSION_COOKIE_SAMESITE}
ENV REDIS_CACHE_HOST=${REDIS_CACHE_HOST}
ENV REDIS_CACHE_PORT=${REDIS_CACHE_PORT}
ENV REDIS_CACHE_DB=${REDIS_CACHE_DB}
ENV REDIS_CACHE_PASSWORD=${REDIS_CACHE_PASSWORD}
ENV REDIS_CACHE_SSL=${REDIS_CACHE_SSL}
ENV REDIS_QUEUE_HOST=${REDIS_QUEUE_HOST}
ENV REDIS_QUEUE_PORT=${REDIS_QUEUE_PORT}
ENV REDIS_QUEUE_DB=${REDIS_QUEUE_DB}
ENV REDIS_QUEUE_PASSWORD=${REDIS_QUEUE_PASSWORD}
ENV REDIS_QUEUE_SSL=${REDIS_QUEUE_SSL}
ENV REDIS_RATE_LIMIT_HOST=${REDIS_RATE_LIMIT_HOST}
ENV REDIS_RATE_LIMIT_PORT=${REDIS_RATE_LIMIT_PORT}
ENV REDIS_RATE_LIMIT_DB=${REDIS_RATE_LIMIT_DB}
ENV REDIS_RATE_LIMIT_PASSWORD=${REDIS_RATE_LIMIT_PASSWORD}
ENV REDIS_RATE_LIMIT_SSL=${REDIS_RATE_LIMIT_SSL}
ENV REDIS_SESSION_HOST=${REDIS_SESSION_HOST}
ENV REDIS_SESSION_PORT=${REDIS_SESSION_PORT}
ENV REDIS_SESSION_DB=${REDIS_SESSION_DB}
ENV REDIS_SESSION_PASSWORD=${REDIS_SESSION_PASSWORD}
ENV REDIS_SESSION_SSL=${REDIS_SESSION_SSL}
ENV REDIS_SESSION_PREFIX=${REDIS_SESSION_PREFIX}
ENV REDIS_SESSION_GC_TTL=${REDIS_SESSION_GC_TTL}
ENV OIDC_ENABLED=${OIDC_ENABLED}
ENV OIDC_PROVIDER_NAME=${OIDC_PROVIDER_NAME}
ENV OIDC_SERVER_METADATA_URL=${OIDC_SERVER_METADATA_URL}
ENV OIDC_CLIENT_ID=${OIDC_CLIENT_ID}
ENV OIDC_CLIENT_SECRET=${OIDC_CLIENT_SECRET}
ENV OIDC_SCOPES=${OIDC_SCOPES}
ENV OIDC_REDIRECT_URI=${OIDC_REDIRECT_URI}
ENV OIDC_REDIRECT_PATH=${OIDC_REDIRECT_PATH}
ENV OIDC_POST_LOGIN_REDIRECT=${OIDC_POST_LOGIN_REDIRECT}
ENV OIDC_ACCESS_DENIED_REDIRECT=${OIDC_ACCESS_DENIED_REDIRECT}
ENV OIDC_GROUP_CLAIM_KEY=${OIDC_GROUP_CLAIM_KEY}
ENV OIDC_ADMIN_GROUP_NAME=${OIDC_ADMIN_GROUP_NAME}
ENV OIDC_APPLICATION_OWNERS_GROUP_NAME=${OIDC_APPLICATION_OWNERS_GROUP_NAME}
ENV CLPP_ADMIN_ROLE_NAME=${CLPP_ADMIN_ROLE_NAME}
ENV CLPP_APPLICATION_OWNERS_ROLE_NAME=${CLPP_APPLICATION_OWNERS_ROLE_NAME}
ENV IBM_SV_ADMIN_BASE_URL=${IBM_SV_ADMIN_BASE_URL}
ENV IBM_SV_ADMIN_CLIENT_ID=${IBM_SV_ADMIN_CLIENT_ID}
ENV IBM_SV_ADMIN_CLIENT_SECRET=${IBM_SV_ADMIN_CLIENT_SECRET}
ENV TIMEZONE=${TIMEZONE}
ENV LOAD_MAU_ENABLED=${LOAD_MAU_ENABLED}
ENV CORS_ORIGINS=${CORS_ORIGINS}
ENV CORS_METHODS=${CORS_METHODS}
ENV CORS_HEADERS=${CORS_HEADERS}
ENV CLIENT_CACHE_MAX_AGE=${CLIENT_CACHE_MAX_AGE}
ENV AWS_S3_REGION=${AWS_S3_REGION}
ENV AWS_S3_ROLE_ARN=${AWS_S3_ROLE_ARN}
ENV AWS_S3_PROFILE=${AWS_S3_PROFILE}
ENV S3_MAU_BUCKET_NAME=${S3_MAU_BUCKET_NAME}
ENV S3_MAU_FOLDER=${S3_MAU_FOLDER}
ENV START_ARQ_ON_STARTUP=${START_ARQ_ON_STARTUP}
ENV CONSOLE_LOG_FORMAT_JSON=${CONSOLE_LOG_FORMAT_JSON}

COPY --from=requirements-stage /tmp/requirements.txt /code/requirements.txt

RUN pip install --no-cache-dir --upgrade -r /code/requirements.txt

# Install gunicorn
RUN pip install gunicorn[gthread] uvicorn[standard]

COPY ./src/app /code/app
COPY ./src/migrations /code/migrations
COPY ./src/alembic.ini /code/alembic.ini

# Create non-root user
RUN adduser --disabled-password --gecos '' appuser \
    && mkdir -p /code/app/logs \
    && chown -R appuser:appuser /code/app/logs
USER appuser

# -------- replace with comment to run with gunicorn --------
# CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
CMD ["gunicorn", "app.main:app", "-w", "4", "-k", "uvicorn.workers.UvicornWorker", "-b", "0.0.0.0:8000"]
