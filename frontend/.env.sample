# Vite client env vars. Copy into `frontend/.env` (or `frontend/.env.local`) and edit as needed.

VITE_APP_ENVIRONMENT="development"
# API backend origin (leave unset to derive from browser host)
VITE_API_BASE_URL="http://localhost:8000"
# Path to redirect to after auth completes (client-side route)
VITE_AUTH_POST_LOGIN_PATH="/dashboard"
# Minutes of backend inactivity before showing warning modal
VITE_SESSION_WARNING_AFTER_MINUTES="25"
# Minutes to count down in warning modal before auto logout
VITE_SESSION_COUNTDOWN_MINUTES="5"
