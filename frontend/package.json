{
	"name": "canadalogin-partner-portal-frontend",
	"author": "CDS Auth Team",
	"description": "CanadaLogin Partner Portal - Vite + React frontend",
	"keywords": [
		"vite",
		"react",
		"canada",
		"gc",
		"partner-portal"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/cds-snc/gc-signin-partner-portal"
	},
	"license": "MIT",
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"setup": "git init && npx husky init && npx playwright install && shx rm .husky/pre-commit",
		"format": "prettier \"src/**/*.{ts,tsx}\" --write",
		"lint": "eslint --max-warnings 0",
		"lint:fix": "eslint --max-warnings 0 --fix",
		"dev": "vite",
		"storybook": "storybook dev -p 6006",
		"storybook:setup": "node node_modules/@storybook/addon-styling/bin/postinstall.js",
		"storybook:build": "storybook build",
		"test": "vitest run tests/unit",
		"test:unit": "vitest tests/unit",
		"test:unit:coverage": "vitest --coverage tests/unit",
		"test:e2e": "playwright test",
		"test:e2e:report": "playwright show-report",
		"build": "tsc && vite build",
		"preview": "vite preview",
		"commitlint": "commitlint --edit",
		"commitizen": "exec < /dev/tty && git cz --hook || true",
		"prepare": "husky"
	},
	"dependencies": {
		"@gcds-core/components": "^1.3.0",
		"@gcds-core/components-react": "^1.3.0",
		"@gcds-core/css-shortcuts": "^1.1.0",
		"@hookform/resolvers": "^5.2.2",
		"@nivo/bar": "^0.99.0",
		"@nivo/core": "^0.99.0",
		"@nivo/line": "^0.99.0",
		"@nivo/pie": "^0.99.0",
		"@storybook/addon-docs": "^10.3.5",
		"@tanstack/react-query": "^5.96.2",
		"@tanstack/react-router": "^1.168.10",
		"@tanstack/react-table": "^8.21.3",
		"dayjs": "^1.11.20",
		"i18next": "^26.0.3",
		"i18next-browser-languagedetector": "^8.2.1",
		"i18next-http-backend": "^3.0.4",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-hook-form": "^7.72.1",
		"react-i18next": "^17.0.2",
		"react-router-dom": "^7.14.0",

		"zod": "^4.3.6",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@faker-js/faker": "^10.4.0",
		"@headlessui/react": "^2.2.10",
		"@heroicons/react": "^2.2.0",
		"@hookform/devtools": "^4.4.0",
		"@playwright/test": "^1.59.1",
		"@storybook/addon-links": "^10.3.5",
		"@storybook/addon-themes": "^10.3.5",
		"@storybook/react-vite": "^10.3.5",
		"@tailwindcss/vite": "^4.2.2",
		"@tanstack/react-query-devtools": "^5.96.2",
		"@tanstack/react-router-devtools": "1.166.11",
		"@tanstack/react-table-devtools": "^8.21.3",
		"@tanstack/router-plugin": "^1.167.12",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@total-typescript/ts-reset": "^0.6.1",
		"@types/node": "^25.5.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript-eslint/eslint-plugin": "^8.58.0",
		"@typescript-eslint/parser": "^8.58.0",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/coverage-v8": "4.1.3",
		"autoprefixer": "^10.4.27",
		"commitizen": "^4.3.1",
		"cz-conventional-changelog": "^3.3.0",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"eslint-plugin-storybook": "^10.3.5",
		"eslint-plugin-unicorn": "^64.0.0",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"jsdom": "^29.0.2",
		"prettier": "^3.8.1",
		"prop-types": "^15.8.1",
		"shx": "^0.4.0",
		"storybook": "^10.3.5",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.0",
		"vite": "8.0.7",
		"vite-plugin-static-copy": "^4.0.1",
		"vitest": "4.1.3"
	},
	"config": {
		"commitizen": {
			"path": "./node_modules/cz-conventional-changelog"
		}
	}
}
